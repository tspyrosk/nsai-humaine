# Ignore Python cache and compiled files
__pycache__/*
*/__pycache__/*
*.pyc
*.pyo
*.pyd

# Ignore environment files
.env
*.env

# Ignore virtual environment directories and files
venv/
.venv/
env/
ENV/
bin/
lib/
lib64/
pyvenv.cfg
include/
share/
etc/
lib64

.idea/

# Ignore data and artifacts
*.db
*.sqlite3
*.h5
*.hdf5
*.ckpt
*.weights


# Ignore any local Dockerfiles or images you don't want bundled
docker-compose.yml
Dockerfile*

# Ignore version control folders
.git/
.gitignore

# Ignore other unnecessary files
*.tar
*.zip
*.gz
*.whl
dist/*
build/*
*.egg-info/*

input/*
output/*
cheatsheet

# Test and coverage artifacts
tests/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/
*.log